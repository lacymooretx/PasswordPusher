# PasswordPusher Environment Variable Template
#
# Copy this file to .env (gitignored) and uncomment/edit values as needed.
# The Config gem maps nested YAML keys from config/settings.yml to env vars
# using the PWP__ prefix with __ as the separator.
#
# Precedence (highest wins):
#   Environment variables > config/settings.local.yml > config/settings.yml
#
# Generate values for keys at: https://pwpush.com/pages/generate_key

# ==============================================================================
# Security & Encryption
# ==============================================================================

# Lockbox encryption key for push payloads. 64-char hex string.
# A default key is used if unset, but production should always set its own.
# Generate with: rails c -> Lockbox.generate_key
# PWPUSH_MASTER_KEY='your-64-char-hex-key-here'

# Comma-separated list of previous master keys for key rotation.
# Allows decryption of old pushes encrypted with prior keys.
# PWPUSH_MASTER_KEY_PREVIOUS='old-key-1,old-key-2'

# Rails session signing/encryption key. Auto-generated in Docker if unset.
# Generate with: ruby -e "require 'securerandom'; puts SecureRandom.hex(64)"
# SECRET_KEY_BASE='your-128-char-hex-key-here'

# ==============================================================================
# Feature Flags
# ==============================================================================

# User accounts (requires SMTP for email). Default: false
# PWP__ENABLE_LOGINS='false'

# Allow anonymous (non-logged-in) users to create pushes. Default: true
# PWP__ALLOW_ANONYMOUS='true'

# Disable new user registration (keeps existing accounts). Default: false
# PWP__DISABLE_SIGNUPS='false'

# Regex to restrict signup email domains. Default: any valid email.
# Example for single domain: '\A[^@\s]+@(hey\.com)\z'
# PWP__SIGNUP_EMAIL_REGEXP='\A[^@\s]+@[^@\s]+\z'

# User-configurable push defaults (expiration, retrieval step, etc.). Default: false
# PWP__ENABLE_USER_POLICIES='false'

# TOTP-based two-factor authentication for user accounts. Default: false
# PWP__ENABLE_TWO_FACTOR='false'

# Per-user branding / white-label on push delivery pages. Default: false
# PWP__ENABLE_USER_BRANDING='false'

# Request / intake forms for third-party submissions. Default: false
# PWP__ENABLE_REQUESTS='false'

# Team collaboration with roles and shared pushes. Default: false
# PWP__ENABLE_TEAMS='false'

# URL-based pushes (requires enable_logins). Default: false
# PWP__ENABLE_URL_PUSHES='false'

# File upload pushes (requires enable_logins + storage config). Default: false
# PWP__ENABLE_FILE_PUSHES='false'

# QR code pushes (requires enable_logins). Default: false
# PWP__ENABLE_QR_PUSHES='false'

# ==============================================================================
# SSO (Single Sign-On)
# ==============================================================================

# Google OAuth2
# PWP__SSO__GOOGLE__ENABLED='false'
# PWP__SSO__GOOGLE__CLIENT_ID='your-google-client-id'
# PWP__SSO__GOOGLE__CLIENT_SECRET='your-google-client-secret'

# Microsoft Graph OAuth2
# PWP__SSO__MICROSOFT__ENABLED='false'
# PWP__SSO__MICROSOFT__CLIENT_ID='your-microsoft-client-id'
# PWP__SSO__MICROSOFT__CLIENT_SECRET='your-microsoft-client-secret'

# ==============================================================================
# Host & URL
# ==============================================================================

# Domain (without protocol) where this instance is hosted. Used for email links.
# PWP__HOST_DOMAIN='pwpush.com'

# Protocol for generating URLs. Default: https
# PWP__HOST_PROTOCOL='https'

# Force a specific base URL for generated push links (no trailing slash).
# PWP__OVERRIDE_BASE_URL='https://pwpush.mydomain.com'

# Allowed hosts for host-header attack prevention (space-separated in env var).
# localhost and the app's own IP are always allowed.
# PWP__ALLOWED_HOSTS='pwpush.com pwpush.mydomain.com'

# ==============================================================================
# Login & Session
# ==============================================================================

# Session timeout without activity. Default: 2 hours
# Examples: "15 minutes", "6 hours", "1 day", "3 weeks"
# PWP__LOGIN_SESSION_TIMEOUT='2 hours'

# ==============================================================================
# Password Push Defaults (pw)
# ==============================================================================

# PWP__PW__EXPIRE_AFTER_DAYS_DEFAULT=7
# PWP__PW__EXPIRE_AFTER_DAYS_MIN=1
# PWP__PW__EXPIRE_AFTER_DAYS_MAX=90

# PWP__PW__EXPIRE_AFTER_VIEWS_DEFAULT=5
# PWP__PW__EXPIRE_AFTER_VIEWS_MIN=1
# PWP__PW__EXPIRE_AFTER_VIEWS_MAX=100

# Enable the 1-click retrieval step feature. Default: true
# PWP__PW__ENABLE_RETRIEVAL_STEP='true'
# Default form checkbox state for retrieval step. Default: false
# PWP__PW__RETRIEVAL_STEP_DEFAULT='false'

# Allow viewers to delete pushes before expiration. Default: true
# PWP__PW__ENABLE_DELETABLE_PUSHES='true'
# Default form checkbox state for deletable. Default: true
# PWP__PW__DELETABLE_PUSHES_DEFAULT='true'

# Blur payload text on the delivery page (click to reveal). Default: true
# PWP__PW__ENABLE_BLUR='true'

# ==============================================================================
# URL Push Defaults (url)
# ==============================================================================

# PWP__URL__EXPIRE_AFTER_DAYS_DEFAULT=7
# PWP__URL__EXPIRE_AFTER_DAYS_MIN=1
# PWP__URL__EXPIRE_AFTER_DAYS_MAX=90

# PWP__URL__EXPIRE_AFTER_VIEWS_DEFAULT=5
# PWP__URL__EXPIRE_AFTER_VIEWS_MIN=1
# PWP__URL__EXPIRE_AFTER_VIEWS_MAX=100

# PWP__URL__ENABLE_RETRIEVAL_STEP='true'
# PWP__URL__RETRIEVAL_STEP_DEFAULT='false'

# ==============================================================================
# File Push Defaults (files)
# ==============================================================================

# PWP__FILES__EXPIRE_AFTER_DAYS_DEFAULT=7
# PWP__FILES__EXPIRE_AFTER_DAYS_MIN=1
# PWP__FILES__EXPIRE_AFTER_DAYS_MAX=90

# PWP__FILES__EXPIRE_AFTER_VIEWS_DEFAULT=5
# PWP__FILES__EXPIRE_AFTER_VIEWS_MIN=1
# PWP__FILES__EXPIRE_AFTER_VIEWS_MAX=100

# PWP__FILES__ENABLE_RETRIEVAL_STEP='true'
# PWP__FILES__RETRIEVAL_STEP_DEFAULT='false'

# PWP__FILES__ENABLE_DELETABLE_PUSHES='true'
# PWP__FILES__DELETABLE_PUSHES_DEFAULT='true'

# Blur file push payload text. Default: true
# PWP__FILES__BLUR='true'

# Maximum number of files per push. Default: 10
# PWP__FILES__MAX_FILE_UPLOADS=10

# ==============================================================================
# File Storage Backend
# ==============================================================================

# Storage backend: local, amazon, minio, google, microsoft. Default: local
# PWP__FILES__STORAGE='local'

# Amazon S3
# PWP__FILES__S3__ENDPOINT=''
# PWP__FILES__S3__ACCESS_KEY_ID=''
# PWP__FILES__S3__SECRET_ACCESS_KEY=''
# PWP__FILES__S3__REGION='us-east-1'
# PWP__FILES__S3__BUCKET='pwpush-files'

# Google Cloud Storage
# PWP__FILES__GCS__PROJECT=''
# PWP__FILES__GCS__CREDENTIALS=''
# PWP__FILES__GCS__BUCKET=''
# PWP__FILES__GCS__IAM='false'
# PWP__FILES__GCS__GSA_EMAIL=''

# Microsoft Azure Blob Storage
# PWP__FILES__AS__STORAGE_ACCOUNT_NAME=''
# PWP__FILES__AS__STORAGE_ACCESS_KEY=''
# PWP__FILES__AS__CONTAINER=''

# ==============================================================================
# QR Code Push Defaults (qr)
# ==============================================================================

# PWP__QR__EXPIRE_AFTER_DAYS_DEFAULT=7
# PWP__QR__EXPIRE_AFTER_DAYS_MIN=1
# PWP__QR__EXPIRE_AFTER_DAYS_MAX=90

# PWP__QR__EXPIRE_AFTER_VIEWS_DEFAULT=5
# PWP__QR__EXPIRE_AFTER_VIEWS_MIN=1
# PWP__QR__EXPIRE_AFTER_VIEWS_MAX=100

# PWP__QR__ENABLE_RETRIEVAL_STEP='true'
# PWP__QR__RETRIEVAL_STEP_DEFAULT='false'

# PWP__QR__ENABLE_DELETABLE_PUSHES='true'
# PWP__QR__DELETABLE_PUSHES_DEFAULT='true'

# ==============================================================================
# Password Generator Defaults
# ==============================================================================

# PWP__GEN__HAS_NUMBERS='true'
# PWP__GEN__TITLE_CASED='true'
# PWP__GEN__USE_SEPARATORS='true'
# PWP__GEN__CONSONANTS='bcdfghklmnprstvz'
# PWP__GEN__VOWELS='aeiouy'
# PWP__GEN__SEPARATORS='-_='
# PWP__GEN__MAX_SYLLABLE_LENGTH=3
# PWP__GEN__MIN_SYLLABLE_LENGTH=1
# PWP__GEN__SYLLABLES_COUNT=3

# ==============================================================================
# Mail / SMTP (required when enable_logins is true)
# ==============================================================================

# PWP__MAIL__RAISE_DELIVERY_ERRORS='false'
# PWP__MAIL__SMTP_ADDRESS='smtp.example.com'
# PWP__MAIL__SMTP_DOMAIN=''
# PWP__MAIL__SMTP_PORT='587'
# PWP__MAIL__SMTP_AUTHENTICATION='plain'
# PWP__MAIL__SMTP_USER_NAME='apikey'
# PWP__MAIL__SMTP_PASSWORD=''
# PWP__MAIL__SMTP_STARTTLS='false'
# PWP__MAIL__SMTP_ENABLE_STARTTLS_AUTO='true'
# PWP__MAIL__SMTP_OPEN_TIMEOUT=10
# PWP__MAIL__SMTP_READ_TIMEOUT=10
# PWP__MAIL__SMTP_OPENSSL_VERIFY_MODE='peer'
# PWP__MAIL__MAILER_SENDER='"Password Pusher" <noreply@example.com>'

# ==============================================================================
# Branding & Theme
# ==============================================================================

# Site title shown in header/browser tab. Default: Password Pusher
# PWP__BRAND__TITLE='Password Pusher'

# Tagline shown below the title. Default: Go Ahead. Email Another Password.
# PWP__BRAND__TAGLINE='Go Ahead.  Email Another Password.'

# Disclaimer text (optional, not set by default).
# PWP__BRAND__DISCLAIMER=''

# Show/hide footer navigation menu. Default: true
# PWP__BRAND__SHOW_FOOTER_MENU='true'

# Custom logo URLs (light and dark theme variants).
# PWP__BRAND__LIGHT_LOGO='https://example.com/logo-light.png'
# PWP__BRAND__DARK_LOGO='https://example.com/logo-dark.png'

# Bootswatch theme name. See https://bootswatch.com/ for options.
# Only configurable via env var, not settings.yml. Default: default
# PWP__THEME='default'

# ==============================================================================
# Rate Limiting (Rack::Attack)
# ==============================================================================

# Max requests per minute from a single client. Default: 120
# PWP__THROTTLING__MINUTE=120

# Max requests per second from a single client. Default: 60
# PWP__THROTTLING__SECOND=60

# ==============================================================================
# Proxies
# ==============================================================================

# Trusted proxy IP addresses (comma-separated).
# PWP__TRUSTED_PROXIES='1.2.3.4,5.6.7.8'

# Fetch Cloudflare proxy IPs on boot and add to trusted proxies. Default: false
# PWP__CLOUDFLARE_PROXY='false'

# ==============================================================================
# Locale & Internationalization
# ==============================================================================

# Default site language. Must be in the enabled_language_codes list. Default: en
# PWP__DEFAULT_LOCALE='en'

# ==============================================================================
# Display & Privacy
# ==============================================================================

# Show app version in the footer. Default: true
# PWP__SHOW_VERSION='true'

# Show GDPR cookie consent banner. Default: true
# PWP__SHOW_GDPR_CONSENT_BANNER='true'

# Application timezone. Default: America/New_York
# See: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
# PWP__TIMEZONE='America/New_York'

# Force HTTPS-only, HttpOnly, SameSite cookies. Default: false
# PWP__SECURE_COOKIES='false'

# Permanently delete expired pushes (and audit logs) after this duration.
# Values: disabled, 3 months, 6 months, 1 year, 2 years, 3 years. Default: disabled
# PWP__PURGE_AFTER='disabled'

# ==============================================================================
# Logging
# ==============================================================================

# Log level: debug, info, warn, error, fatal. Default: warn
# PWP__LOG_LEVEL='warn'

# Log to stdout instead of log files (useful in containers). Default: false
# PWP__LOG_TO_STDOUT='false'

# ==============================================================================
# Database
# ==============================================================================

# Override the default SQLite database with PostgreSQL or MySQL.
# DATABASE_URL='postgres://user:pass@localhost:5432/pwpush_production'
# DATABASE_URL='mysql2://user:pass@localhost:3306/pwpush_production'

# Connection pool size. Default: 5
# DB_POOL=5

# ==============================================================================
# Docker / Container
# ==============================================================================

# Precompile assets on container boot (for custom themes). Default: false
# PWP_PRECOMPILE='false'

# ==============================================================================
# Error Tracking (Rollbar)
# ==============================================================================

# PWP uses Rollbar for error tracking. Set token to enable.
# ROLLBAR_ACCESS_TOKEN=''
# ROLLBAR_ENV='production'
