<% title(_('Webhook Details')) %>

<main>
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2><%= _('Webhook Details') %></h2>
    <div class="d-flex gap-2">
      <%= link_to edit_webhook_path(@webhook), class: "btn btn-outline-secondary" do %>
        <em class="bi bi-pencil"></em> <%= _('Edit') %>
      <% end %>
      <%= button_to webhook_path(@webhook), method: :delete, class: "btn btn-outline-danger", data: { turbo_confirm: _("Are you sure you want to delete this webhook?") } do %>
        <em class="bi bi-trash"></em> <%= _('Delete') %>
      <% end %>
    </div>
  </div>

  <div class="card mb-4">
    <div class="card-body">
      <dl class="row mb-0">
        <dt class="col-sm-3"><%= _('URL') %></dt>
        <dd class="col-sm-9"><code><%= @webhook.url %></code></dd>

        <dt class="col-sm-3"><%= _('Status') %></dt>
        <dd class="col-sm-9">
          <% if @webhook.enabled? %>
            <span class="badge bg-success"><%= _('Active') %></span>
          <% else %>
            <span class="badge bg-danger"><%= _('Disabled') %></span>
          <% end %>
        </dd>

        <dt class="col-sm-3"><%= _('Events') %></dt>
        <dd class="col-sm-9">
          <% Array(@webhook.events).each do |event| %>
            <span class="badge bg-secondary"><%= event %></span>
          <% end %>
        </dd>

        <dt class="col-sm-3"><%= _('Signing Secret') %></dt>
        <dd class="col-sm-9">
          <% if @webhook.secret.present? %>
            <code class="user-select-all"><%= @webhook.secret %></code>
          <% else %>
            <span class="text-muted"><%= _('Not set') %></span>
          <% end %>
        </dd>

        <dt class="col-sm-3"><%= _('Failure Count') %></dt>
        <dd class="col-sm-9"><%= @webhook.failure_count %></dd>

        <dt class="col-sm-3"><%= _('Last Success') %></dt>
        <dd class="col-sm-9"><%= @webhook.last_success_at ? l(@webhook.last_success_at) : '-' %></dd>

        <dt class="col-sm-3"><%= _('Last Failure') %></dt>
        <dd class="col-sm-9">
          <% if @webhook.last_failure_at %>
            <%= l(@webhook.last_failure_at) %>
            <br><small class="text-muted"><%= @webhook.last_failure_reason %></small>
          <% else %>
            -
          <% end %>
        </dd>
      </dl>
    </div>
  </div>

  <h4 class="mb-3"><%= _('Recent Deliveries') %></h4>

  <% if @deliveries.any? %>
    <div class="table-responsive">
      <table class="table table-hover">
        <thead>
          <tr>
            <th><%= _('Status') %></th>
            <th><%= _('Event') %></th>
            <th><%= _('Response') %></th>
            <th><%= _('Attempt') %></th>
            <th><%= _('Time') %></th>
          </tr>
        </thead>
        <tbody>
          <% @deliveries.each do |delivery| %>
            <tr>
              <td>
                <% if delivery.success? %>
                  <span class="badge bg-success"><%= _('OK') %></span>
                <% else %>
                  <span class="badge bg-danger"><%= _('Failed') %></span>
                <% end %>
              </td>
              <td><span class="badge bg-secondary"><%= delivery.event %></span></td>
              <td><%= delivery.response_code || '-' %></td>
              <td><%= delivery.attempt %></td>
              <td><%= l(delivery.created_at, format: :short) %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
    <%= paginate @deliveries %>
  <% else %>
    <p class="text-muted"><%= _('No deliveries yet.') %></p>
  <% end %>

  <div class="mt-3">
    <%= link_to _('Back to Webhooks'), webhooks_path, class: "btn btn-outline-secondary" %>
  </div>
</main>
