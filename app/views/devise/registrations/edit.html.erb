<% title(I18n.t('devise.registrations.edit_account')) %>

<main class=''>
  <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put }) do |f| %>
    <%= render "devise/shared/error_messages", resource: resource %>

    <p class='my-3 py-3 lead border-bottom'><%= I18n.t('devise.registrations.update_email') %></p>
    <div class="form-floating">
      <%= f.email_field :email, class: 'form-control', autofocus: true, autocomplete: "email", placeholder: "name@example.org" %>
      <%= f.label _('Change Email'), for: :user_email %>
    </div>

    <% if devise_mapping.confirmable? && resource.pending_reconfirmation? %>
      <div><%= I18n.t('devise.registrations.currently_waiting') %>: <%= resource.unconfirmed_email %></div>
    <% end %>

    <% if I18n.available_locales.length > 1 %>
      <p class='my-3 py-3 lead border-bottom'><%= I18n.t('devise.registrations.preferred_language') %></p>
      <div class="form-group">
        <%= f.select :preferred_language,  options_for_select(language_options_for_select, resource.preferred_language || I18n.locale), { selected: resource.preferred_language || I18n.locale }, { class: "form-control" } %>
      </div>
    <% end %>

    <% unless resource.sso_user? %>
      <p class='my-3 py-3 lead border-bottom'><%= I18n.t('devise.registrations.change_password') %></p>
      <p class=''><%= I18n.t('devise.registrations.change_password_hint') %></p>
      <div class="form-floating">
        <%= f.password_field :password, class: 'form-control', autocomplete: "new-password", placeholder: I18n.t('devise.registrations.new_password') %>
        <%= f.label I18n.t('devise.registrations.new_password'), for: :user_password %>
      </div>
      <div class="form-floating">
        <%= f.password_field :password_confirmation, class: 'form-control', autocomplete: "new-password", placeholder: I18n.t('devise.registrations.password') %>
        <%= f.label I18n.t('devise.registrations.new_password_confirmation'), for: :user_password_confirmation %>
      </div>

      <% if @minimum_password_length %>
        <p class='text-muted mt-3 fs-7'>
        * <%= sprintf(I18n.t('devise.registrations.password_minimum'), @minimum_password_length) %>
        </p>
      <% end %>

      <p class='my-3 py-3 lead border-bottom'><%= I18n.t('devise.registrations.verification') %></p>
      <p class='text-muted'><%= I18n.t('devise.registrations.verification_text') %></p>

      <div class="form-floating">
        <%= f.password_field :current_password, class: 'form-control', autocomplete: "current-password", placeholder: I18n.t('devise.registrations.password') %>
        <%= f.label _("Current Password"), for: :user_current_password %>
      </div>
    <% end %>

    <% if Settings.respond_to?(:enable_push_notifications) && Settings.enable_push_notifications %>
      <p id="push-notifications" class='my-3 py-3 lead border-bottom'><%= _('Push Notifications') %></p>
      <p class="text-muted"><%= _('Choose which email notifications you want to receive about your pushes.') %></p>
      <div class="form-check mb-2">
        <%= f.check_box :notify_on_view, class: "form-check-input", id: "notify_on_view" %>
        <%= f.label :notify_on_view, _('Notify me when a push is viewed'), class: "form-check-label" %>
      </div>
      <div class="form-check mb-2">
        <%= f.check_box :notify_on_expire, class: "form-check-input", id: "notify_on_expire" %>
        <%= f.label :notify_on_expire, _('Notify me when a push expires'), class: "form-check-label" %>
      </div>
      <div class="form-check mb-2">
        <%= f.check_box :notify_on_expiring_soon, class: "form-check-input", id: "notify_on_expiring_soon" %>
        <%= f.label :notify_on_expiring_soon, _('Notify me when a push is about to expire (within 24 hours)'), class: "form-check-label" %>
      </div>
    <% end %>

    <div class="form-floating my-3">
      <button class="w-100 btn btn-lg btn-primary mt-3" type="submit"><%= I18n.t('devise.registrations.update_account') %></button>
    </div>
  <% end %>

  <% if Settings.respond_to?(:enable_two_factor) && Settings.enable_two_factor %>
    <p class='my-3 py-3 lead border-bottom'><%= _('Two-Factor Authentication') %></p>
    <% if resource.otp_enabled? %>
      <div class="d-flex align-items-center gap-3 mb-3">
        <span class="badge bg-success"><%= _('Enabled') %></span>
        <span class="text-muted"><%= _('Your account is protected with two-factor authentication.') %></span>
      </div>
      <div class="d-flex gap-2">
        <%= link_to _('Regenerate Backup Codes'), regenerate_backup_codes_users_two_factor_path, class: "btn btn-outline-secondary" %>
        <button type="button" class="btn btn-outline-danger" data-bs-toggle="modal" data-bs-target="#disable2faModal">
          <%= _('Disable 2FA') %>
        </button>
      </div>

      <!-- Disable 2FA Modal -->
      <div class="modal fade" id="disable2faModal" tabindex="-1">
        <div class="modal-dialog">
          <div class="modal-content">
            <%= form_tag(disable_users_two_factor_path, method: :delete) do %>
              <div class="modal-header">
                <h5 class="modal-title"><%= _('Disable Two-Factor Authentication') %></h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
              </div>
              <div class="modal-body">
                <% if resource.sso_user? %>
                  <p><%= _('Are you sure you want to disable two-factor authentication?') %></p>
                <% else %>
                  <p><%= _('Enter your password to confirm disabling two-factor authentication.') %></p>
                  <div class="form-floating">
                    <%= password_field_tag :password, nil, class: "form-control", placeholder: _("Password"), autocomplete: "current-password" %>
                    <label for="password"><%= _('Password') %></label>
                  </div>
                <% end %>
              </div>
              <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal"><%= _('Cancel') %></button>
                <button type="submit" class="btn btn-danger"><%= _('Disable 2FA') %></button>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    <% else %>
      <p class="text-muted"><%= _('Add an extra layer of security to your account by enabling two-factor authentication.') %></p>
      <%= link_to _('Set Up Two-Factor Authentication'), setup_users_two_factor_path, class: "btn btn-outline-primary" %>
    <% end %>
  <% end %>

  <p class='my-3 py-3 lead border-top'><%= I18n.t('devise.registrations.edit.cancel_my_account') %></p>
  <p class='text-muted'><%= I18n.t('devise.registrations.edit.cancel_my_account_description') %></p>

  <%= button_to I18n.t('devise.registrations.edit.cancel_my_account'),
                registration_path(resource_name),
                data: { turbo_confirm: I18n.t('devise.registrations.edit.are_you_sure') },
                method: :delete,
                class: "btn btn-outline-danger" %>
</main>
