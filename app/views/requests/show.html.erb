<% title(@request.name) %>

<main>
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h3><%= @request.name %></h3>
    <div class="d-flex gap-2">
      <%= link_to _('Edit'), edit_request_path(@request), class: "btn btn-outline-secondary" %>
      <% if @request.active? %>
        <%= button_to _('Deactivate'), request_path(@request), method: :delete, class: "btn btn-outline-danger", data: { turbo_confirm: _("Are you sure?") } %>
      <% end %>
    </div>
  </div>

  <div class="card mb-4">
    <div class="card-body">
      <div class="row">
        <div class="col-md-6">
          <p><strong><%= _('Status:') %></strong>
            <% if @request.active? %>
              <span class="badge bg-success"><%= _('Active') %></span>
            <% else %>
              <span class="badge bg-secondary"><%= _('Expired') %></span>
            <% end %>
          </p>
          <p><strong><%= _('Submissions:') %></strong> <%= @request.submission_count %><%= " / #{@request.max_submissions}" if @request.max_submissions %></p>
          <p><strong><%= _('Accepts:') %></strong>
            <%= _('Text') if @request.allow_text? %>
            <%= _('Files') if @request.allow_files? %>
            <%= _('URLs') if @request.allow_url? %>
          </p>
        </div>
        <div class="col-md-6">
          <p><strong><%= _('Created:') %></strong> <%= l(@request.created_at, format: :long) %></p>
          <% if @request.expires_at %>
            <p><strong><%= _('Expires:') %></strong> <%= l(@request.expires_at, format: :long) %></p>
          <% end %>
        </div>
      </div>

      <% if @request.description.present? %>
        <p class="text-muted mt-2"><strong><%= _('Description:') %></strong> <%= @request.description %></p>
      <% end %>
    </div>
  </div>

  <% if @request.active? %>
    <div class="card mb-4">
      <div class="card-body">
        <h5><%= _('Share this link') %></h5>
        <div class="input-group">
          <input type="text" class="form-control" value="<%= request_submission_url(@request) %>" readonly id="request-link">
          <button class="btn btn-outline-secondary" type="button" onclick="navigator.clipboard.writeText(document.getElementById('request-link').value)">
            <%= _('Copy') %>
          </button>
        </div>
      </div>
    </div>
  <% end %>

  <% if @request.pushes.any? %>
    <h5 class="mb-3"><%= _('Submissions') %></h5>
    <div class="table-responsive">
      <table class="table table-hover">
        <thead>
          <tr>
            <th><%= _('Type') %></th>
            <th><%= _('Submitted') %></th>
            <th><%= _('Status') %></th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% @request.pushes.order(created_at: :desc).each do |push| %>
            <tr>
              <td><span class="badge bg-info"><%= push.kind %></span></td>
              <td><%= l(push.created_at, format: :short) %></td>
              <td>
                <% if push.expired? %>
                  <span class="badge bg-secondary"><%= _('Expired') %></span>
                <% else %>
                  <span class="badge bg-success"><%= _('Active') %></span>
                <% end %>
              </td>
              <td><%= link_to _('View'), push_path(push), class: "btn btn-sm btn-outline-secondary" %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% end %>

  <div class="mt-3">
    <%= link_to _('Back to Requests'), requests_path, class: "btn btn-link" %>
  </div>
</main>
