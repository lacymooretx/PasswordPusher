<h4 class="mb-3 border-bottom pb-2">
  <em class="bi bi-eye-slash me-2 text-primary"></em><%= _('Hidden Features') %>
</h4>
<p class="text-muted small mb-3"><%= _('Push types hidden from team members will not appear in push creation forms.') %></p>

<% hidden_features = @policy.fetch("hidden_features", {}) %>
<% feature_labels = {
  "url_pushes" => _("URL Pushes"),
  "file_pushes" => _("File Pushes"),
  "qr_pushes" => _("QR Code Pushes")
} %>

<div class="card">
  <div class="card-body">
    <% if hidden_features.any? %>
      <div class="d-flex flex-wrap gap-2">
        <% feature_labels.each do |feature, label| %>
          <% if hidden_features[feature] %>
            <span class="badge bg-danger bg-opacity-10 text-danger border border-danger border-opacity-25 px-3 py-2">
              <em class="bi bi-eye-slash me-1"></em><%= label %>
            </span>
          <% else %>
            <span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-25 px-3 py-2">
              <em class="bi bi-eye me-1"></em><%= label %>
            </span>
          <% end %>
        <% end %>
      </div>
    <% else %>
      <p class="text-muted fst-italic mb-0"><%= _('No features hidden. All push types are visible to team members.') %></p>
    <% end %>
  </div>
</div>
