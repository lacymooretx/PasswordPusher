<% title(_('Policy & Settings: %{team}') % { team: @team.name }) %>

<div class="d-flex justify-content-between align-items-start mb-4">
  <div>
    <h1 class="h3 mb-1"><%= _('Policy & Settings') %></h1>
    <p class="text-muted mb-0"><%= _('Current policy configuration for this team.') %></p>
  </div>
  <% if @team.admin?(current_user) %>
    <%= link_to edit_team_policy_path(@team), class: 'btn btn-primary btn-sm' do %>
      <em class="bi bi-pencil me-1"></em><%= _('Edit Policy') %>
    <% end %>
  <% end %>
</div>

<%= render 'category_nav' %>

<!-- Pushes Section -->
<div id="pushes" class="mb-5">
  <h4 class="mb-3 border-bottom pb-2">
    <em class="bi bi-clipboard me-2 text-primary"></em><%= _('Push Settings') %>
  </h4>

  <% kind_labels = { "pw" => _("Text"), "url" => _("URL"), "file" => _("File"), "qr" => _("QR Code") } %>
  <% kind_icons = { "pw" => "bi-lock", "url" => "bi-link-45deg", "file" => "bi-file-earmark", "qr" => "bi-qr-code" } %>

  <div class="row g-3">
    <% %w[pw url file qr].each do |kind| %>
      <div class="col-md-6">
        <div class="card h-100">
          <div class="card-header d-flex align-items-center">
            <em class="bi <%= kind_icons[kind] %> me-2 text-primary"></em>
            <h6 class="mb-0"><%= kind_labels[kind] %> <%= _('Pushes') %></h6>
          </div>
          <div class="card-body">
            <% defaults = @policy.dig("defaults", kind) || {} %>
            <% forced = @policy.dig("forced", kind) || {} %>
            <% limits = @policy.dig("limits", kind) || {} %>

            <!-- Expiration -->
            <p class="text-muted small text-uppercase fw-semibold mb-2"><%= _('Expiration Defaults') %></p>
            <dl class="row mb-3">
              <dt class="col-sm-7 fw-normal text-muted small"><%= _('Expire after days') %></dt>
              <dd class="col-sm-5 mb-0 small">
                <% if defaults["expire_after_days"].present? %>
                  <span class="fw-semibold"><%= defaults["expire_after_days"] %></span>
                  <% if forced["expire_after_days"] %>
                    <span class="badge bg-warning text-dark ms-1 small"><em class="bi bi-lock-fill"></em> <%= _('Forced') %></span>
                  <% end %>
                <% else %>
                  <span class="text-muted fst-italic"><%= _('Not set') %></span>
                <% end %>
              </dd>

              <dt class="col-sm-7 fw-normal text-muted small"><%= _('Expire after views') %></dt>
              <dd class="col-sm-5 mb-0 small">
                <% if defaults["expire_after_views"].present? %>
                  <span class="fw-semibold"><%= defaults["expire_after_views"] %></span>
                  <% if forced["expire_after_views"] %>
                    <span class="badge bg-warning text-dark ms-1 small"><em class="bi bi-lock-fill"></em> <%= _('Forced') %></span>
                  <% end %>
                <% else %>
                  <span class="text-muted fst-italic"><%= _('Not set') %></span>
                <% end %>
              </dd>
            </dl>

            <!-- Options -->
            <p class="text-muted small text-uppercase fw-semibold mb-2"><%= _('Options') %></p>
            <dl class="row mb-3">
              <dt class="col-sm-7 fw-normal text-muted small"><%= _('Retrieval step') %></dt>
              <dd class="col-sm-5 mb-0 small">
                <% if defaults.key?("retrieval_step") %>
                  <span class="badge <%= defaults['retrieval_step'] ? 'bg-success' : 'bg-secondary' %>">
                    <%= defaults['retrieval_step'] ? _('Enabled') : _('Disabled') %>
                  </span>
                  <% if forced["retrieval_step"] %>
                    <span class="badge bg-warning text-dark ms-1 small"><em class="bi bi-lock-fill"></em></span>
                  <% end %>
                <% else %>
                  <span class="text-muted fst-italic small"><%= _('Not set') %></span>
                <% end %>
              </dd>

              <dt class="col-sm-7 fw-normal text-muted small"><%= _('Deletable by viewer') %></dt>
              <dd class="col-sm-5 mb-0 small">
                <% if defaults.key?("deletable_pushes") %>
                  <span class="badge <%= defaults['deletable_pushes'] ? 'bg-success' : 'bg-secondary' %>">
                    <%= defaults['deletable_pushes'] ? _('Enabled') : _('Disabled') %>
                  </span>
                  <% if forced["deletable_pushes"] %>
                    <span class="badge bg-warning text-dark ms-1 small"><em class="bi bi-lock-fill"></em></span>
                  <% end %>
                <% else %>
                  <span class="text-muted fst-italic small"><%= _('Not set') %></span>
                <% end %>
              </dd>
            </dl>

            <!-- Limits -->
            <% if limits.any? %>
              <p class="text-muted small text-uppercase fw-semibold mb-2"><%= _('Limits') %></p>
              <dl class="row mb-0">
                <% if limits["expire_after_days_max"].present? %>
                  <dt class="col-sm-7 fw-normal text-muted small"><%= _('Max days') %></dt>
                  <dd class="col-sm-5 mb-0 small fw-semibold"><%= limits["expire_after_days_max"] %></dd>
                <% end %>
                <% if limits["expire_after_views_max"].present? %>
                  <dt class="col-sm-7 fw-normal text-muted small"><%= _('Max views') %></dt>
                  <dd class="col-sm-5 mb-0 small fw-semibold"><%= limits["expire_after_views_max"] %></dd>
                <% end %>
              </dl>
            <% end %>

            <% if defaults.empty? && forced.empty? && limits.empty? %>
              <p class="text-muted small fst-italic mb-0"><%= _('No policy configured for this push type. Global defaults apply.') %></p>
            <% end %>
          </div>
        </div>
      </div>
    <% end %>
  </div>
</div>

<!-- Hidden Features Section -->
<div id="hidden-features" class="mb-5">
  <h4 class="mb-3 border-bottom pb-2">
    <em class="bi bi-eye-slash me-2 text-primary"></em><%= _('Hidden Features') %>
  </h4>

  <% hidden_features = @policy.fetch("hidden_features", {}) %>
  <% feature_labels = {
    "url_pushes" => _("URL Pushes"),
    "file_pushes" => _("File Pushes"),
    "qr_pushes" => _("QR Code Pushes")
  } %>

  <div class="card">
    <div class="card-body">
      <p class="text-muted small mb-3"><%= _('Push types hidden from team members will not appear in push creation forms.') %></p>
      <% if hidden_features.any? %>
        <div class="d-flex flex-wrap gap-2">
          <% feature_labels.each do |feature, label| %>
            <% if hidden_features[feature] %>
              <span class="badge bg-danger bg-opacity-10 text-danger border border-danger border-opacity-25 px-3 py-2">
                <em class="bi bi-eye-slash me-1"></em><%= label %>
              </span>
            <% end %>
          <% end %>
        </div>
      <% else %>
        <p class="text-muted fst-italic mb-0"><%= _('No features hidden. All push types are visible to team members.') %></p>
      <% end %>
    </div>
  </div>
</div>

<% if @team.admin?(current_user) %>
  <div class="mt-4 pt-2 border-top">
    <%= link_to edit_team_policy_path(@team), class: 'btn btn-primary' do %>
      <em class="bi bi-pencil me-1"></em><%= _('Edit Policy') %>
    <% end %>
  </div>
<% end %>
