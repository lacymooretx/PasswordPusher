<% title(_('Branding Settings')) %>

<main class="">
  <h3 class="mb-4"><%= _('Branding Settings') %></h3>
  <p class="text-muted mb-4"><%= _('Customize how your push delivery pages appear to recipients.') %></p>

  <%= form_for(@user_branding, url: user_branding_path, html: { method: :patch, multipart: true }) do |f| %>
    <% if @user_branding.errors.any? %>
      <div class="alert alert-danger">
        <% @user_branding.errors.full_messages.each do |msg| %>
          <p class="mb-0"><%= msg %></p>
        <% end %>
      </div>
    <% end %>

    <p class="my-3 py-3 lead border-bottom"><%= _('Delivery Page') %></p>

    <div class="mb-3">
      <%= f.label :delivery_heading, _('Heading'), class: "form-label" %>
      <%= f.text_field :delivery_heading, class: "form-control", placeholder: _("e.g. Secure message from Acme Corp") %>
      <div class="form-text"><%= _("Shown at the top of the delivery page when recipients view your pushes.") %></div>
    </div>

    <div class="mb-3">
      <%= f.label :delivery_message, _('Message'), class: "form-label" %>
      <%= f.text_area :delivery_message, class: "form-control", rows: 3, placeholder: _("e.g. This secure message was sent by our team...") %>
      <div class="form-text"><%= _("Optional message displayed below the heading.") %></div>
    </div>

    <div class="mb-3">
      <%= f.label :delivery_footer, _('Footer Text'), class: "form-label" %>
      <%= f.text_field :delivery_footer, class: "form-control", placeholder: _("e.g. © 2026 Acme Corp") %>
    </div>

    <p class="my-3 py-3 lead border-bottom"><%= _('Logo') %></p>

    <div class="mb-3">
      <% if @user_branding.logo.attached? %>
        <div class="mb-2">
          <strong><%= _('Current logo:') %></strong><br>
          <%= image_tag @user_branding.logo, style: "max-height: 80px; max-width: 200px;" %>
        </div>
      <% end %>
      <%= f.label :logo, _('Upload Logo'), class: "form-label" %>
      <%= f.file_field :logo, class: "form-control", accept: "image/png,image/jpeg,image/svg+xml,image/webp" %>
      <div class="form-text"><%= _("PNG, JPEG, SVG, or WebP. Displayed on your delivery pages.") %></div>
    </div>

    <div class="mb-3">
      <% if @user_branding.dark_logo.attached? %>
        <div class="mb-2">
          <strong><%= _('Current dark mode logo:') %></strong><br>
          <%= image_tag @user_branding.dark_logo, style: "max-height: 80px; max-width: 200px; background: #333; padding: 8px; border-radius: 4px;" %>
        </div>
      <% end %>
      <%= f.label :dark_logo, _('Upload Dark Mode Logo'), class: "form-label" %>
      <%= f.file_field :dark_logo, class: "form-control", accept: "image/png,image/jpeg,image/svg+xml,image/webp" %>
      <div class="form-text"><%= _("Displayed when the user is in dark mode. If not set, the regular logo is used.") %></div>
    </div>

    <p class="my-3 py-3 lead border-bottom"><%= _('White Label') %></p>

    <div class="form-check mb-3">
      <%= f.check_box :white_label, class: "form-check-input" %>
      <%= f.label :white_label, _('Enable white-label mode'), class: "form-check-label" %>
      <div class="form-text"><%= _("Hides PasswordPusher branding and replaces it with your custom branding.") %></div>
    </div>

    <div class="mb-3">
      <%= f.label :brand_title, _('Brand Title'), class: "form-label" %>
      <%= f.text_field :brand_title, class: "form-control", placeholder: _("e.g. Acme Secure Share") %>
    </div>

    <div class="mb-3">
      <%= f.label :brand_tagline, _('Brand Tagline'), class: "form-label" %>
      <%= f.text_field :brand_tagline, class: "form-control", placeholder: _("e.g. Secure password sharing for teams") %>
    </div>

    <p class="my-3 py-3 lead border-bottom"><%= _('Colors') %></p>

    <div class="row mb-3">
      <div class="col-md-6">
        <%= f.label :primary_color, _('Primary Color'), class: "form-label" %>
        <div class="input-group">
          <%= f.color_field :primary_color, class: "form-control form-control-color", value: @user_branding.primary_color || "#0d6efd" %>
          <%= f.text_field :primary_color, class: "form-control", placeholder: "#0d6efd", id: nil %>
        </div>
      </div>
      <div class="col-md-6">
        <%= f.label :background_color, _('Background Color'), class: "form-label" %>
        <div class="input-group">
          <%= f.color_field :background_color, class: "form-control form-control-color", value: @user_branding.background_color || "#ffffff" %>
          <%= f.text_field :background_color, class: "form-control", placeholder: "#ffffff", id: nil %>
        </div>
      </div>
    </div>

    <div class="my-3">
      <button class="w-100 btn btn-lg btn-primary mt-3" type="submit"><%= _('Save Branding Settings') %></button>
    </div>
  <% end %>
</main>
