<div class="container">
  <header class="d-flex flex-wrap justify-content-center py-3 mb-4 border-bottom">
    <%= link_to root_path, class: 'd-flex align-items-center mb-3 mb-md-0 me-md-auto text-body-emphasis text-decoration-none', hreflang: locale.to_s do %>
      <div class='me-2'>
      <picture>
        <% if Settings.brand.nil? || Settings.brand.light_logo.nil? %>
          <source srcset="<%= asset_path('logo-transparent-sm-bare.png') %>" media="(prefers-color-scheme: light) or (prefers-color-scheme: no-preference)">
          <source srcset="<%= asset_path('logo-transparent-sm-dark-bare.png') %>" media="(prefers-color-scheme: dark)">
          <img src="<%= asset_path('logo-transparent-sm-bare.png') %>" alt="<%= _('Password Pusher Logo') %>" style='height: 50px;'>
        <% else %>
          <source srcset="<%= Settings.brand.light_logo %>" media="(prefers-color-scheme: light) or (prefers-color-scheme: no-preference)">
          <source srcset="<%= Settings.brand.dark_logo %>" media="(prefers-color-scheme: dark)">
          <img src="<%= Settings.brand.light_logo %>" alt="<%= _('Password Pusher Logo') %>" style='height: 50px;'>
        <% end %>
      </picture>
      </div>
      <div>
        <span class="fs-4 display-1"><%= Settings.brand.title %></span>
        <br>
        <span class="fs-6 text-muted"><%= Settings.brand.tagline %></span>
      </div>
    <% end %>

    <ul class="nav nav-pills align-items-center">
      <% if Settings.enable_logins %>
        <% if current_user %>
          <%# Top-level Pushes nav item %>
          <li class="nav-item">
            <%= link_to pushes_path, class: "nav-link d-flex align-items-center #{'active' if current_page?(pushes_path)}" do %>
              <em class="bi bi-send me-1"></em>
              <%= _('Pushes') %>
            <% end %>
          </li>

          <%# Top-level Requests nav item (if enabled) %>
          <% if Settings.respond_to?(:enable_requests) && Settings.enable_requests %>
            <li class="nav-item">
              <%= link_to requests_path, class: "nav-link d-flex align-items-center #{'active' if current_page?(requests_path)}" do %>
                <em class="bi bi-inbox me-1"></em>
                <%= _('Requests') %>
              <% end %>
            </li>
          <% end %>

          <%# Teams dropdown / team switcher (if enabled and user has teams) %>
          <% if Settings.respond_to?(:enable_teams) && Settings.enable_teams %>
            <% user_teams = current_user.teams.order(:name) %>
            <% if user_teams.any? %>
              <li class="nav-item dropdown">
                <a class="nav-link dropdown-toggle d-flex align-items-center" href="#" id="teamSwitcherDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                  <em class="bi bi-people me-1"></em>
                  <% primary_team = user_teams.first %>
                  <%= truncate(primary_team.name, length: 20) %>
                </a>
                <ul class="dropdown-menu" aria-labelledby="teamSwitcherDropdown">
                  <% user_teams.each do |team| %>
                    <li>
                      <%= link_to team_path(team), class: "dropdown-item d-flex align-items-center" do %>
                        <em class="bi bi-people me-2"></em>
                        <%= team.name %>
                        <% membership = team.membership_for(current_user) %>
                        <% if membership %>
                          <span class="badge bg-secondary ms-auto"><%= membership.role.humanize %></span>
                        <% end %>
                      <% end %>
                    </li>
                  <% end %>
                  <li><hr class="dropdown-divider"></li>
                  <li>
                    <%= link_to teams_path, class: "dropdown-item d-flex align-items-center" do %>
                      <em class="bi bi-grid me-2"></em>
                      <%= _('All Teams') %>
                    <% end %>
                  </li>
                  <li>
                    <%= link_to new_team_path, class: "dropdown-item d-flex align-items-center" do %>
                      <em class="bi bi-plus-circle me-2"></em>
                      <%= _('Create Team') %>
                    <% end %>
                  </li>
                </ul>
              </li>
            <% else %>
              <li class="nav-item">
                <%= link_to teams_path, class: "nav-link d-flex align-items-center" do %>
                  <em class="bi bi-people me-1"></em>
                  <%= _('Teams') %>
                <% end %>
              </li>
            <% end %>
          <% end %>

          <%# Account dropdown (slimmed down) %>
          <li class="nav-item dropdown">
            <a class="nav-link dropdown-toggle" href="#" id="accountDropdownMenuLink" role="button" data-bs-toggle="dropdown" aria-expanded="false">
              <em class='bi bi-person-circle'></em>
            </a>
            <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="accountDropdownMenuLink">
              <% if current_user.admin? %>
                <li>
                  <%= link_to admin_root_path, class: "dropdown-item d-flex align-items-center" do %>
                    <em class="bi bi-shield-check me-2"></em>
                    <%= _('Administration Center') %>
                  <% end %>
                </li>
                <li><hr class="dropdown-divider"></li>
              <% end %>
              <li>
                <%= link_to edit_user_registration_path, class: "dropdown-item d-flex align-items-center" do %>
                  <em class="bi bi-pencil-square me-2"></em>
                  <%= _('Edit Login Details') %>
                <% end %>
              </li>
              <li>
                <%= link_to token_user_registration_path, class: "dropdown-item d-flex align-items-center" do %>
                  <em class="bi bi-key me-2"></em>
                  <%= _('API Token') %>
                <% end %>
              </li>
              <% if Settings.respond_to?(:enable_user_policies) && Settings.enable_user_policies %>
                <li>
                  <%= link_to edit_user_policy_path, class: "dropdown-item d-flex align-items-center" do %>
                    <em class="bi bi-sliders me-2"></em>
                    <%= _('Push Defaults') %>
                  <% end %>
                </li>
              <% end %>
              <% if Settings.respond_to?(:enable_user_branding) && Settings.enable_user_branding %>
                <li>
                  <%= link_to edit_user_branding_path, class: "dropdown-item d-flex align-items-center" do %>
                    <em class="bi bi-palette me-2"></em>
                    <%= _('Branding') %>
                  <% end %>
                </li>
              <% end %>
              <% if Settings.respond_to?(:enable_audit_dashboard) && Settings.enable_audit_dashboard %>
                <li>
                  <%= link_to audit_dashboard_index_path, class: "dropdown-item d-flex align-items-center" do %>
                    <em class="bi bi-clipboard-data me-2"></em>
                    <%= _('Audit Log') %>
                  <% end %>
                </li>
              <% end %>
              <% if Settings.respond_to?(:enable_webhooks) && Settings.enable_webhooks %>
                <li>
                  <%= link_to webhooks_path, class: "dropdown-item d-flex align-items-center" do %>
                    <em class="bi bi-lightning me-2"></em>
                    <%= _('Webhooks') %>
                  <% end %>
                </li>
              <% end %>
              <li><hr class="dropdown-divider"></li>
              <li>
                <%= button_to destroy_user_session_path, method: :delete, class: "dropdown-item d-flex align-items-center w-100", form_class: "d-inline w-100" do %>
                  <em class="bi bi-box-arrow-right me-2"></em>
                  <%= _('Log Out') %>
                <% end %>
              </li>
            </ul>
          </li>
        <% else %>
          <li class="nav-item">
            <%= link_to _('Log In'), new_user_session_path, class: "nav-link lead" %>
          </li>
          <% if !Settings.disable_signups %>
            <li class="nav-item">
              <%= link_to _('Sign Up'), new_user_registration_path, class: "nav-link lead" %>
            </li>
          <% end %>
        <% end %>
      <% end %>
    </ul>
  </header>
</div>
