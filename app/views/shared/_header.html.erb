<div class="container">
  <header class="d-flex flex-wrap justify-content-center py-3 mb-4 border-bottom">
    <% header_teams = current_user_teams %>
    <% header_primary_team = header_teams.first %>
    <% header_branding = header_primary_team&.team_branding %>
    <%= link_to root_path, class: 'd-flex align-items-center mb-3 mb-md-0 me-md-auto text-body-emphasis text-decoration-none', hreflang: locale.to_s do %>
      <div class='me-2'>
      <% if header_branding&.logo&.attached? %>
        <% if header_branding.dark_logo.attached? %>
          <%= image_tag header_branding.logo, alt: header_branding.brand_title || _('Logo'), style: 'height: 50px;', class: 'light-logo' %>
          <%= image_tag header_branding.dark_logo, alt: header_branding.brand_title || _('Logo'), style: 'height: 50px;', class: 'dark-logo' %>
        <% else %>
          <%= image_tag header_branding.logo, alt: header_branding.brand_title || _('Logo'), style: 'height: 50px;' %>
        <% end %>
      <% elsif Settings.brand.present? && Settings.brand.light_logo.present? %>
        <img src="<%= Settings.brand.light_logo %>" alt="<%= _('Password Pusher Logo') %>" style="height: 50px;" class="light-logo">
        <img src="<%= Settings.brand.dark_logo %>" alt="<%= _('Password Pusher Logo') %>" style="height: 50px;" class="dark-logo">
      <% else %>
        <img src="<%= asset_path('logo-transparent-sm-bare.png') %>" alt="<%= _('Password Pusher Logo') %>" style="height: 50px;" class="light-logo">
        <img src="<%= asset_path('logo-transparent-sm-dark-bare.png') %>" alt="<%= _('Password Pusher Logo') %>" style="height: 50px;" class="dark-logo">
      <% end %>
      </div>
      <div>
        <span class="fs-4 display-1"><%= header_branding&.white_label? && header_branding.brand_title.present? ? header_branding.brand_title : Settings.brand.title %></span>
      </div>
    <% end %>

    <ul class="nav nav-pills align-items-center">
      <% if Settings.enable_logins %>
        <% if current_user %>
          <%# Top-level Pushes nav item %>
          <li class="nav-item">
            <%= link_to pushes_path, class: "nav-link #{'active' if current_page?(pushes_path)}" do %>
              <%= _('Pushes') %>
            <% end %>
          </li>

          <%# Top-level Requests nav item (if enabled) %>
          <% if Settings.respond_to?(:enable_requests) && Settings.enable_requests %>
            <li class="nav-item">
              <%= link_to requests_path, class: "nav-link #{'active' if current_page?(requests_path)}" do %>
                <%= _('Requests') %>
              <% end %>
            </li>
          <% end %>

          <%# What's New link (if configured) %>
          <% if Settings.brand.respond_to?(:whats_new_url) && Settings.brand.whats_new_url.present? %>
            <li class="nav-item">
              <%= link_to _("What's New"), Settings.brand.whats_new_url, target: "_blank", rel: "noopener noreferrer", class: "nav-link" %>
            </li>
          <% end %>

          <%# Notification bell (if push notifications enabled) %>
          <% if Settings.respond_to?(:enable_push_notifications) && Settings.enable_push_notifications %>
            <li class="nav-item me-2">
              <%= link_to edit_user_registration_path(anchor: "push-notifications"), class: "nav-link position-relative", aria_label: _('Notifications'), title: _('Notification Preferences') do %>
                <em class="bi bi-bell"></em>
              <% end %>
            </li>
          <% end %>

          <%# Dark mode toggle %>
          <li class="nav-item me-2">
            <button class="nav-link btn btn-link" data-action="click->theme#toggle" title="<%= _('Toggle dark mode') %>" aria-label="<%= _('Toggle dark mode') %>">
              <em class="bi bi-sun-fill" data-theme-target="icon"></em>
            </button>
          </li>

          <%# Account dropdown with team/user avatar %>
          <% user_teams = current_user_teams %>
          <% primary_team = header_primary_team %>
          <li class="nav-item dropdown">
            <a class="nav-link dropdown-toggle d-flex align-items-center" href="#" id="accountDropdownMenuLink" role="button" data-bs-toggle="dropdown" aria-expanded="false">
              <% if primary_team %>
                <span class="d-inline-flex align-items-center justify-content-center rounded-circle bg-primary text-white fw-bold me-1" style="width: 28px; height: 28px; font-size: 0.75rem;">
                  <%= primary_team.name.first.upcase %>
                </span>
                <span class="d-none d-md-inline"><%= truncate(primary_team.name, length: 20) %></span>
              <% else %>
                <% if current_user.avatar_url.present? %>
                  <img src="<%= current_user.avatar_url %>" alt="" class="rounded-circle me-1" style="width: 28px; height: 28px; object-fit: cover;">
                <% else %>
                  <span class="d-inline-flex align-items-center justify-content-center rounded-circle bg-primary text-white fw-bold me-1" style="width: 28px; height: 28px; font-size: 0.75rem;">
                    <%= current_user.email.first.upcase %>
                  </span>
                <% end %>
                <span class="d-none d-md-inline"><%= truncate(current_user.email, length: 24) %></span>
              <% end %>
            </a>
            <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="accountDropdownMenuLink">
              <%# === Team Section === %>
              <% if primary_team %>
                <li>
                  <h6 class="dropdown-header d-flex align-items-center">
                    <span class="d-inline-flex align-items-center justify-content-center rounded-circle bg-primary text-white fw-bold me-2" style="width: 24px; height: 24px; font-size: 0.65rem;">
                      <%= primary_team.name.first.upcase %>
                    </span>
                    <%= primary_team.name %>
                  </h6>
                </li>
                <li>
                  <%= link_to team_path(primary_team), class: "dropdown-item" do %>
                    <%= _('Account Overview') %>
                  <% end %>
                </li>
                <% if primary_team.admin?(current_user) %>
                  <li>
                    <%= link_to edit_team_policy_path(primary_team), class: "dropdown-item" do %>
                      <%= _('Policy & Settings') %>
                    <% end %>
                  </li>
                  <% if Settings.respond_to?(:enable_user_branding) && Settings.enable_user_branding %>
                    <li>
                      <%= link_to edit_team_branding_path(primary_team), class: "dropdown-item" do %>
                        <%= _('Branding') %>
                      <% end %>
                    </li>
                  <% end %>
                  <li>
                    <%= link_to team_path(primary_team, anchor: 'invite'), class: "dropdown-item" do %>
                      <%= _('Invite a User') %>
                    <% end %>
                  </li>
                <% end %>
                <% if current_user.admin? %>
                  <li>
                    <%= link_to admin_root_path, class: "dropdown-item" do %>
                      <%= _('Admin Center') %>
                    <% end %>
                  </li>
                <% end %>
                <% if user_teams.size > 1 %>
                  <li><hr class="dropdown-divider"></li>
                  <li>
                    <%= link_to teams_path, class: "dropdown-item" do %>
                      <%= _('Switch Account') %>
                    <% end %>
                  </li>
                <% end %>
                <li><hr class="dropdown-divider"></li>
              <% else %>
                <% if current_user.admin? %>
                  <li>
                    <%= link_to admin_root_path, class: "dropdown-item" do %>
                      <%= _('Admin Center') %>
                    <% end %>
                  </li>
                  <li><hr class="dropdown-divider"></li>
                <% end %>
              <% end %>

              <%# === User Section === %>
              <li>
                <h6 class="dropdown-header d-flex align-items-center">
                  <% if current_user.avatar_url.present? %>
                    <img src="<%= current_user.avatar_url %>" alt="" class="rounded-circle me-2" style="width: 24px; height: 24px; object-fit: cover;">
                  <% else %>
                    <span class="d-inline-flex align-items-center justify-content-center rounded-circle bg-secondary text-white fw-bold me-2" style="width: 24px; height: 24px; font-size: 0.65rem;">
                      <%= current_user.email.first.upcase %>
                    </span>
                  <% end %>
                  <%= truncate(current_user.email, length: 28) %>
                </h6>
              </li>
              <li>
                <%= link_to edit_user_registration_path, class: "dropdown-item" do %>
                  <%= _('Profile') %>
                <% end %>
              </li>
              <% if Settings.respond_to?(:enable_two_factor) && Settings.enable_two_factor %>
                <li>
                  <%= link_to setup_users_two_factor_path, class: "dropdown-item" do %>
                    <%= _('Password & 2FA') %>
                  <% end %>
                </li>
              <% end %>
              <li>
                <%= link_to token_user_registration_path, class: "dropdown-item" do %>
                  <%= _('API Tokens') %>
                <% end %>
              </li>
              <li><hr class="dropdown-divider"></li>
              <li>
                <%= button_to destroy_user_session_path, method: :delete, class: "dropdown-item w-100", form_class: "d-inline w-100" do %>
                  <%= _('Sign Out') %>
                <% end %>
              </li>
            </ul>
          </li>
        <% else %>
          <li class="nav-item">
            <%= link_to _('Log In'), new_user_session_path, class: "nav-link lead" %>
          </li>
          <% if !Settings.disable_signups %>
            <li class="nav-item">
              <%= link_to _('Sign Up'), new_user_registration_path, class: "nav-link lead" %>
            </li>
          <% end %>
        <% end %>
      <% end %>
    </ul>
  </header>
</div>
