<footer class="footer mt-auto py-3">
  <div class="container">
    <% if Settings.brand.show_footer_menu %>
      <%# Top links row %>
      <div class="d-flex flex-wrap justify-content-center gap-4 py-3 border-top">
        <% if Settings.brand.respond_to?(:best_practices_url) && Settings.brand.best_practices_url.present? %>
          <%= link_to _('Best Practices'), Settings.brand.best_practices_url, target: "_blank", rel: "noopener noreferrer", class: "text-muted text-decoration-none" %>
        <% end %>
        <%= link_to _('API Documentation'), "/api-docs", class: "text-muted text-decoration-none" %>
        <% faq_url = (Settings.brand.respond_to?(:faq_url) && Settings.brand.faq_url.present?) ? Settings.brand.faq_url : "https://docs.pwpush.com/docs/faq/" %>
        <%= link_to _('FAQ'), faq_url, target: "_blank", rel: "noopener noreferrer", class: "text-muted text-decoration-none" %>
        <% if Settings.brand.respond_to?(:support_url) && Settings.brand.support_url.present? %>
          <%= link_to _('Help'), Settings.brand.support_url, target: "_blank", rel: "noopener noreferrer", class: "text-muted text-decoration-none" %>
        <% elsif Settings.brand.respond_to?(:help_url) && Settings.brand.help_url.present? %>
          <%= link_to _('Help'), Settings.brand.help_url, target: "_blank", rel: "noopener noreferrer", class: "text-muted text-decoration-none" %>
        <% end %>
      </div>
    <% end %>

    <%# Logo centered %>
    <% footer_teams = current_user_teams %>
    <% footer_branding = footer_teams.first&.team_branding %>
    <div class="d-flex justify-content-center my-3">
      <%= link_to root_path(locale: locale.to_s), class: "link-dark text-decoration-none" do %>
        <% if footer_branding&.logo&.attached? %>
          <%= image_tag footer_branding.logo, alt: footer_branding.brand_title || _('Logo'), style: 'height: 40px;' %>
        <% elsif Settings.brand.present? && Settings.brand.light_logo.present? %>
          <picture>
            <source srcset="<%= Settings.brand.light_logo %>" media="(prefers-color-scheme: light) or (prefers-color-scheme: no-preference)">
            <source srcset="<%= Settings.brand.dark_logo %>" media="(prefers-color-scheme: dark)">
            <img src="<%= Settings.brand.light_logo %>" alt="<%= _('Password Pusher Logo') %>" style='height: 40px;'>
          </picture>
        <% else %>
          <picture>
            <source srcset="<%= asset_path('logo-transparent-sm-bare.png') %>" media="(prefers-color-scheme: light) or (prefers-color-scheme: no-preference)">
            <source srcset="<%= asset_path('logo-transparent-sm-dark-bare.png') %>" media="(prefers-color-scheme: dark)">
            <img src="<%= asset_path('logo-transparent-sm-bare.png') %>" alt="<%= _('Password Pusher Logo') %>" style='height: 40px;'>
          </picture>
        <% end %>
      <% end %>
    </div>

    <%# Legal links %>
    <% has_legal_links = (Settings.brand.respond_to?(:privacy_url) && Settings.brand.privacy_url.present?) ||
                         (Settings.brand.respond_to?(:terms_url) && Settings.brand.terms_url.present?) %>
    <% if has_legal_links %>
      <div class="d-flex flex-wrap justify-content-center gap-3 mb-3">
        <% if Settings.brand.respond_to?(:privacy_url) && Settings.brand.privacy_url.present? %>
          <%= link_to _('Privacy Policy'), Settings.brand.privacy_url, target: "_blank", rel: "noopener noreferrer", class: "text-muted small text-decoration-none" %>
        <% end %>
        <% if Settings.brand.respond_to?(:terms_url) && Settings.brand.terms_url.present? %>
          <%= link_to _('Terms of Service'), Settings.brand.terms_url, target: "_blank", rel: "noopener noreferrer", class: "text-muted small text-decoration-none" %>
        <% end %>
      </div>
    <% end %>

    <%# Copyright %>
    <p class="text-center text-muted mb-0">&copy; <%= Time.now.year %> <%= footer_branding&.white_label? && footer_branding.brand_title.present? ? footer_branding.brand_title : "PasswordPusher" %></p>

    <%# Disclaimer %>
    <% if Settings.brand.disclaimer %>
      <div>
        <p class="fw-light fst-italic text-center" style="font-size: .9rem;"><%= Settings.brand.disclaimer %></p>
      </div>
    <% end %>
  </div>
</footer>
