<%# Collapsible "Additional Options" section. Pass a block to render the
    advanced controls that should be hidden behind the toggle. See GH #4348. %>
<div class="row mb-3">
    <div class="col">
        <div class="d-flex align-items-center w-100 mt-2 mb-3">
            <span class="text-muted text-nowrap"><em class="bi bi-gear me-1"></em><%= _('Additional Options') %></span>
            <div class="flex-grow-1 border-top mx-3"></div>
            <button
                type="button"
                class="d-flex align-items-center btn btn-outline-secondary rounded-pill btn-sm px-3"
                data-bs-toggle="collapse"
                data-bs-target="#additionalOptionsCollapse"
                aria-expanded="false"
                aria-controls="additionalOptionsCollapse">
                <em class="bi bi-plus me-1"></em>
                <%= _('Show / Hide') %>
            </button>
        </div>

        <div class="collapse" id="additionalOptionsCollapse">
            <%= yield %>
        </div>
    </div>
</div>
