<div class="container h-100">
  <div class="d-flex flex-column min-vh-100 justify-content-center align-items-center">
    <div class="text-center" style="max-width: 480px;">
      <div class="mb-4">
        <em class="bi bi-shield-lock" style="font-size: 3rem;"></em>
      </div>
      <h2 class="mb-3"><%= _('Secure Content Awaiting') %></h2>
      <p class="text-muted mb-4">
        <%= _('Someone has shared a secret with you. Click the button below to view it securely.') %>
      </p>
      <p class="mb-4">
        <%= link_to @secret_url,
          class: "btn btn-primary btn-lg px-5",
          "data-turbo-prefetch": false,
          "data-turbolinks": false,
          "data-turbo": false,
          rel: "no-prefetch" do %>
          <em class="bi bi-unlock"></em> <%= _('View Secret') %>
        <% end %>
      </p>
      <p class="text-muted small">
        <em class="bi bi-info-circle"></em>
        <%= _('This extra step protects against link scanners and chat previews from consuming views.') %>
      </p>
    </div>
  </div>
</div>
