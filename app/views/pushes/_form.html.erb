<% title(_('Securely Send a Password')) %>

<% encryption_enabled = Settings.files.enable_encryption && Settings.enable_file_pushes %>
<div class='container'
    data-controller="knobs pwgen passwords form<%= ' encrypted-upload' if encryption_enabled %>"
    <%= "data-encrypted-upload-enabled-value=true data-encrypted-upload-direct-upload-url-value=#{rails_direct_uploads_url} data-encrypted-upload-multipart-url-value=#{"/pfb/multipart_uploads"}" if encryption_enabled %>
    data-knobs-tab-name-value="password"
    data-knobs-lang-day-value="<%= _('Day') %>"
    data-knobs-lang-days-value="<%= _('Days') %>"
    data-knobs-default-days-value="<%= @push.persisted? ? @push.days_remaining : effective_default(@push.settings_for_kind, :expire_after_days_default, 'text') %>"
    data-knobs-lang-view-value="<%= _('View') %>"
    data-knobs-lang-views-value="<%= _('Views') %>"
    data-knobs-default-views-value="<%= @push.persisted? ? @push.views_remaining : effective_default(@push.settings_for_kind, :expire_after_views_default, 'text') %>"
    data-knobs-lang-save-value="<%= _('Save') %>"
    data-knobs-lang-saved-value="<%= _('Saved!') %>"
    data-knobs-default-retrieval-step-value="<%= effective_default(@push.settings_for_kind, :retrieval_step_default, 'text') %>"
    data-knobs-default-deletable-by-viewer-value="<%= effective_default(@push.settings_for_kind, :deletable_pushes_default, 'text') %>"
    data-pwgen-use-numbers-default-value="<%= Settings.gen.has_numbers %>"
    data-pwgen-title-cased-default-value="<%= Settings.gen.title_cased %>"
    data-pwgen-use-separators-default-value="<%= Settings.gen.use_separators %>"
    data-pwgen-consonants-default-value="<%= Settings.gen.consonants %>"
    data-pwgen-vowels-default-value="<%= Settings.gen.vowels %>"
    data-pwgen-separators-default-value="<%= Settings.gen.separators %>"
    data-pwgen-min-syllable-length-default-value="<%= Settings.gen.min_syllable_length %>"
    data-pwgen-max-syllable-length-default-value="<%= Settings.gen.max_syllable_length %>"
    data-pwgen-syllables-count-default-value="<%= Settings.gen.syllables_count %>"
    data-pwgen-mode-default-value="<%= Settings.gen.mode %>"
    data-pwgen-passphrase-word-count-default-value="<%= Settings.gen.passphrase_word_count %>"
    data-pwgen-passphrase-separator-default-value="<%= Settings.gen.passphrase_separator %>"
    data-pwgen-passphrase-capitalize-default-value="<%= Settings.gen.passphrase_capitalize %>"
    data-pwgen-passphrase-include-number-default-value="<%= Settings.gen.passphrase_include_number %>"
    data-knobs-ga-enabled-value="<%= ENV.key?('GA_ENABLE') %>">
<%= render partial: "shared/topnav" %>
<%= form_for @push, html: { multipart: true }, data: { action: "form#submit#{' submit->encrypted-upload#handleSubmit' if encryption_enabled}" } do |f| %>
    <%= render partial: "pushes/error", locals: {push: @push} %>

    <%= f.hidden_field :kind, value: :text unless action_name == 'edit' %>

    <div class='row'>
        <div class='col'>
            <% payload_blurred = action_name == 'edit' && @push.text? && @push.settings_for_kind.enable_blur %>
            <% if payload_blurred %>
                <div class="payload-reveal-zone rounded-3 px-3 pt-4 pb-4 mb-2 bg-light border">
                    <p class="d-flex align-items-center gap-2 text-muted small mb-2 mb-md-3 mb-lg-3">
                        <em class="bi bi-eye-slash flex-shrink-0" aria-hidden="true"></em>
                        <span><%= _('Content is hidden for privacy. Click the field below to reveal and edit.') %></span>
                    </p>
            <% end %>
            <%= f.text_area(:payload, { class: "form-control#{' spoiler' if payload_blurred}",
                                        rows: 6,
                                        placeholder: _('Enter the Password or Text to push...'),
                                        autocomplete: "off",
                                        spellcheck: "false",
                                        autofocus: !payload_blurred,
                                        required: true,
                                        "data-pwgen-target" => "payloadInput",
                                        "data-passwords-target" => "payloadInput",
                                        "data-action" => "input->passwords#updateCharacterCount pwgen#setContentNotGenerated"
                                         }) %>
            <% if payload_blurred %>
                </div>
            <% end %>
            <div class='position-relative'>
                <div id="the-count" class="position-absolute bottom-0 end-0 m-2 px-3 opacity-75">
                    <span id="current" data-passwords-target="currentChars">0</span>
                    <span id="maximum" data-passwords-target="maximumChars">/ 1048576 <%= _('Characters') %></span>
                </div>
            </div>
            <p class="fst-italic text-muted small mt-2 mb-0">
                <em class="bi bi-lightbulb"></em>
                <%= _('Tip: For maximum security, send usernames, passwords and locations in separate pushes.') %>
            </p>
        </div>
    </div>

    <% if Settings.enable_file_pushes && user_signed_in? && action_name != 'edit' %>
        <div class='row mt-3'>
            <div class='col'>
                <div class="card">
                    <h5 class="card-header"><em class="bi bi-paperclip"></em> <%= _('Attach Files') %></h5>
                    <div class="card-body">
                        <div id="progress-bars" class="list-group"></div>
                        <div data-controller="multi-upload" data-multi-upload-max-files-value="<%= Settings.files.max_file_uploads %>">
                            <div id="selected-files" data-multi-upload-target="files" class="list-group"></div>
                            <div class="file my-3">
                                <%= file_field_tag "push[files][]",
                                                   multiple: true,
                                                   direct_upload: !encryption_enabled,
                                                   class: "form-control",
                                                   "data-action": "multi-upload#addFile" %>
                            </div>
                        </div>
                    </div>
                    <div class="card-footer text-muted">
                        <%= _('Optional: You can attach up to %{count} files to this push.') % { count: Settings.files.max_file_uploads } %>
                        <% if encryption_enabled %>
                            <span class="badge bg-success ms-2"><i class="bi bi-shield-lock"></i> <%= _('End-to-end encrypted') %></span>
                        <% end %>
                    </div>
                </div>
            </div>
        </div>
    <% end %>

    <div class='row'>
        <div class='col-12 col-sm-8 p-3'>
            <div class='row'>
                <div><%= _('Expire secret link and delete after:') %></div>
                <div class='col-10'>
                    <%= range_field_tag("push_expire_after_days", @push.persisted? ? @push.days_remaining : effective_default(@push.settings_for_kind, :expire_after_days_default, 'text'),
                                        { :name => "push[expire_after_days]",
                                          :class => "form-range",
                                          :min => action_name == 'edit' ? @push.days_old + 1 : @push.settings_for_kind.expire_after_days_min,
                                          :max => @push.settings_for_kind.expire_after_days_max,
                                          :step => "1",
                                          "data-action" => "change->knobs#updateDaysSlider input->knobs#updateDaysSlider",
                                          "data-knobs-target" => "daysRange"
                                        }) %>
                </div>
                <div class='col-2'>
                    <div class="form-text" data-knobs-target="daysRangeLabel"><%= @push.persisted? ? @push.days_remaining : effective_default(@push.settings_for_kind, :expire_after_days_default, 'text') %> <%= _('Days') %></div>
                </div>
            </div>
            <div class='row'>
                <div class='col-10'>
                    <%= range_field_tag("push_expire_after_views", @push.persisted? ? @push.views_remaining : effective_default(@push.settings_for_kind, :expire_after_views_default, 'text'),
                                        { :name => "push[expire_after_views]",
                                            :class => "form-range",
                                            :min => action_name == 'edit' ? @push.view_count + 1 : @push.settings_for_kind.expire_after_views_min,
                                            :max => @push.settings_for_kind.expire_after_views_max,
                                            :step => "1",
                                            "data-action" => "change->knobs#updateViewsSlider input->knobs#updateViewsSlider",
                                            "data-knobs-target" => "viewsRange"
                                        }) %>
                </div>

                <div class='col-2'>
                    <div class="form-text" data-knobs-target="viewsRangeLabel"><%= @push.persisted? ? @push.views_remaining : effective_default(@push.settings_for_kind, :expire_after_views_default, 'text') %> <%= _('Views') %></div>
                </div>
            </div>
            <div class='row'>
                <div class='col'>
                    <p class='text-center form-text'><%= _('(whichever comes first)') %></p>
                </div>
            </div>

            <div class='row mb-3'>
                <div class='col'>
                    <div class="list-group mx-0">
                        <% if @push.settings_for_kind.enable_retrieval_step %>
                            <label class="list-group-item d-flex gap-2">
                            <%= check_box_tag "push[retrieval_step]", '1', @push.persisted? ? @push.retrieval_step : effective_default(@push.settings_for_kind, :retrieval_step_default, 'text'), checkbox_options_for_push(@push, "retrievalStep", effective_default(@push.settings_for_kind, :retrieval_step_default, 'text')) %>
                            <span>
                                <%= _('Use a 1-click retrieval step') %>
                                <small class="d-block text-muted"><%= _('Helps to avoid chat systems and URL scanners from eating up views.') %></small>
                            </span>
                            </label>
                        <% end %>
                        <% if @push.settings_for_kind.enable_deletable_pushes %>
                            <label class="list-group-item d-flex gap-2">
                            <%= check_box_tag "push[deletable_by_viewer]", '1', @push.persisted? ? @push.deletable_by_viewer : effective_default(@push.settings_for_kind, :deletable_pushes_default, 'text'), checkbox_options_for_push(@push, "deletableByViewer", effective_default(@push.settings_for_kind, :deletable_pushes_default, 'text')) %>
                            <span>
                                <%= _('Allow immediate deletion') %>
                                <small class="d-block text-muted"><%= _('Allow users to delete this push once retrieved.') %></small>
                            </span>
                            </label>
                        <% end %>
                    </div>
                </div>
            </div>
            <div class='row mb-3'>
                <div class='col'>
                    <fieldset class="border rounded p-3">
                        <legend class="float-none w-auto px-2 fs-6 mb-0">
                            <em class="bi bi-lock"></em> <%= _('Passphrase Lockdown') %>
                        </legend>
                        <%= f.text_field(:passphrase, { class: "form-control",
                                                        autocomplete: "off",
                                                        placeholder: _('Optional: Require recipients to enter a passphrase to view this push') }) %>
                    </fieldset>
                </div>
            </div>

            <% if Settings.enable_auto_dispatch && user_signed_in? && action_name != 'edit' %>
                <div class='row mb-3'>
                    <div class='col'>
                        <hr>
                        <p class="d-inline-flex gap-1 mb-2">
                            <button class="btn btn-outline-secondary btn-sm" type="button" data-bs-toggle="collapse" data-bs-target="#additionalOptions" aria-expanded="false" aria-controls="additionalOptions">
                                <em class="bi bi-gear"></em> <%= _('Additional Options') %> &mdash; <%= _('Show / Hide') %>
                            </button>
                        </p>
                        <div class="collapse" id="additionalOptions">
                            <div class="card">
                                <div class="card-header">
                                    <em class="bi bi-send"></em> <%= _('Auto Dispatch: Send This Secret Link To...') %>
                                </div>
                                <div class="card-body">
                                    <p class="text-muted small mb-2">
                                        <%= _('Enter email addresses separated by commas. The secret link will be emailed to each recipient after the push is created.') %>
                                    </p>
                                    <%= text_field_tag 'dispatch_emails', nil, class: "form-control",
                                        placeholder: _('e.g. alice@example.com, bob@example.com'),
                                        autocomplete: "off" %>
                                    <div class="form-text">
                                        <%= _('Maximum %{count} recipients.') % { count: Settings.auto_dispatch.max_recipients } %>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            <% end %>

            <% unless action_name == 'edit' %>
                <div class='row'>
                    <div class='col'>
                        <p class='mb-3'>
                            <div id='cookie-save'>
                                <a data-action="click->knobs#saveSettings" href="#"><%= _('Save') %></a> <%= _('the above settings as the page default.') %>
                            </div>
                        </p>
                    </div>
                </div>
            <% end %>
        </div>
        <div class='col-12 col-sm-4 p-3 mt-3'>
            <div class="row mb-3">
                <div class="d-flex gap-2 mb-3">
                    <button class="btn btn-secondary flex-grow-1" type="button"
                        id='generate_password'
                        data-knobs-target="generatePasswordButton"
                        data-action="pwgen#producePassword passwords#updateCharacterCount">
                        <em class="bi bi-cpu"></em> <%= _('Generate Password') %>
                    </button>
                    <button class="btn btn-secondary" type="button" id='configure_generator'
                        data-action="pwgen#configureGenerator"
                        data-bs-toggle="modal" data-bs-target="#configureModal">
                        <em class="bi bi-gear"></em>
                    </button>
                </div>
            </div>
            <% if user_signed_in? %>
                <div class='row mb-3'>
                    <label for="push_name" class="form-label fw-semibold"><%= Push.human_attribute_name(:name) %></label>
                    <%= f.text_field(:name, { class: "form-control",
                                            placeholder: _('e.g. Server login for client X'),
                                            autocomplete: "off" }) %>
                    <div class="form-text"><%= _('A name shown in the dashboard, notifications and emails.') %></div>
                </div>
                <div class='row mb-3'>
                    <label for="push_note" class="form-label fw-semibold"><%= _('Reference Note') %></label>
                    <%= f.text_area(:note, { class: "form-control",
                                            rows: 2,
                                            placeholder: _('e.g. Sent to John for the migration project'),
                                            autocomplete: "off" }) %>
                    <div class="form-text"><%= _('Encrypted and visible only to you') %></div>
                </div>
            <% end %>
            <div class='row my-3 px-5'> <hr> </div>
            <div class='row mb-3'>
                <ul class="list-unstyled">
                    <li class="mb-2"><em class="bi bi-shield-lock text-primary"></em> <%= _('All content is encrypted and available only via the secret link.') %></li>
                    <li class="mb-2"><em class="bi bi-trash text-primary"></em> <%= _('Once expired, encrypted content is permanently deleted.') %></li>
                    <li class="mb-2"><em class="bi bi-journal-text text-primary"></em> <%= _('An audit log of all access is available for your pushes.') %></li>
                    <li class="mb-2"><em class="bi bi-sliders text-primary"></em> <%= _('Configure expiration, passphrases and more above.') %></li>
                </ul>
            </div>
            <% if Settings.respond_to?(:enable_user_policies) && Settings.enable_user_policies && user_signed_in? %>
                <div class='row mb-3'>
                    <%= link_to edit_user_policy_path, class: "btn btn-outline-secondary btn-sm w-100" do %>
                        <em class="bi bi-sliders2"></em> <%= _('Manage Account Policy Defaults') %>
                    <% end %>
                </div>
            <% end %>
        </div>
    </div>
    <div class='row'>
        <div class='col'>
            <p class='my-3'>
                <% if @push.persisted? %>
                    <button class="form-control btn btn-primary" type="submit" data-form-target="pushit" data-disable-with="<%= _('Updating...') %>"><%= _('Update Push') %></button>
                <% else %>
                    <button class="form-control btn btn-primary" type="submit" data-form-target="pushit" data-disable-with="<%= _('Pushing...') %>"><%= _('Push It!') %></button>
                <% end %>
            </p>
        </div>
    </div>
<% end %>

<%= render partial: 'shared/pw_generator_modal', cached: true %>
<%= render partial: 'shared/pw_generate_confirm_modal', cached: true %>

</div>
