<% title(@push_template.name) %>

<main>
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2><%= @push_template.name %></h2>
    <div class="d-flex gap-2">
      <%= link_to edit_push_template_path(@push_template), class: "btn btn-outline-secondary" do %>
        <em class="bi bi-pencil"></em> <%= _('Edit') %>
      <% end %>
      <%= button_to push_template_path(@push_template), method: :delete, class: "btn btn-outline-danger", data: { turbo_confirm: _("Are you sure you want to delete this template?") } do %>
        <em class="bi bi-trash"></em> <%= _('Delete') %>
      <% end %>
    </div>
  </div>

  <div class="card mb-4">
    <div class="card-body">
      <dl class="row mb-0">
        <dt class="col-sm-3"><%= _('Kind') %></dt>
        <dd class="col-sm-9"><span class="badge bg-secondary"><%= @push_template.kind.capitalize %></span></dd>

        <dt class="col-sm-3"><%= _('Expire After Days') %></dt>
        <dd class="col-sm-9"><%= @push_template.expire_after_days || _('Default') %></dd>

        <dt class="col-sm-3"><%= _('Expire After Views') %></dt>
        <dd class="col-sm-9"><%= @push_template.expire_after_views || _('Default') %></dd>

        <dt class="col-sm-3"><%= _('Retrieval Step') %></dt>
        <dd class="col-sm-9">
          <% if @push_template.retrieval_step.nil? %>
            <%= _('Default') %>
          <% elsif @push_template.retrieval_step %>
            <span class="badge bg-success"><%= _('Enabled') %></span>
          <% else %>
            <span class="badge bg-secondary"><%= _('Disabled') %></span>
          <% end %>
        </dd>

        <dt class="col-sm-3"><%= _('Deletable by Viewer') %></dt>
        <dd class="col-sm-9">
          <% if @push_template.deletable_by_viewer.nil? %>
            <%= _('Default') %>
          <% elsif @push_template.deletable_by_viewer %>
            <span class="badge bg-success"><%= _('Enabled') %></span>
          <% else %>
            <span class="badge bg-secondary"><%= _('Disabled') %></span>
          <% end %>
        </dd>

        <dt class="col-sm-3"><%= _('Passphrase') %></dt>
        <dd class="col-sm-9"><%= @push_template.passphrase.present? ? _('Set') : _('Not set') %></dd>

        <dt class="col-sm-3"><%= _('Shared With') %></dt>
        <dd class="col-sm-9">
          <% if @push_template.team.present? %>
            <span class="badge bg-secondary"><%= @push_template.team.name %></span>
          <% else %>
            <%= _('Personal') %>
          <% end %>
        </dd>

        <dt class="col-sm-3"><%= _('Created') %></dt>
        <dd class="col-sm-9"><%= l(@push_template.created_at) %></dd>
      </dl>
    </div>
  </div>

  <div class="mt-3">
    <%= link_to _('Back to Templates'), push_templates_path, class: "btn btn-outline-secondary" %>
  </div>
</main>
