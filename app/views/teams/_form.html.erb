<%= form_with(model: @team, class: 'needs-validation') do |f| %>
  <% if @team.errors.any? %>
    <div class="alert alert-danger">
      <ul class="mb-0">
        <% @team.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mb-3">
    <%= f.label :name, _('Team Name'), class: 'form-label' %>
    <%= f.text_field :name, class: 'form-control', required: true, maxlength: 100 %>
  </div>

  <div class="mb-3">
    <%= f.label :description, _('Description'), class: 'form-label' %>
    <%= f.text_area :description, class: 'form-control', rows: 3 %>
  </div>

  <div class="mb-3">
    <%= f.label :avatar, _('Team Avatar'), class: 'form-label' %>
    <% if @team.persisted? && @team.avatar.attached? %>
      <div class="mb-2">
        <%= image_tag @team.avatar, class: "rounded-circle", style: "width: 64px; height: 64px; object-fit: cover;" %>
      </div>
    <% end %>
    <%= f.file_field :avatar, class: 'form-control', accept: "image/png,image/jpeg,image/svg+xml,image/webp" %>
    <div class="form-text"><%= _("Square image recommended. Will be displayed as a circle.") %></div>
  </div>

  <div class="d-flex gap-2">
    <%= f.submit @team.persisted? ? _('Update Team') : _('Create Team'), class: 'btn btn-primary' %>
    <% if @team.persisted? %>
      <%= link_to _('Cancel'), team_path(@team), class: 'btn btn-secondary' %>
    <% else %>
      <%= link_to _('Cancel'), teams_path, class: 'btn btn-secondary' %>
    <% end %>
  </div>
<% end %>
