<% title(_('My Teams')) %>

<div class="container mt-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="display-6"><%= _('My Teams') %></h1>
    <%= link_to new_team_path, class: 'btn btn-primary' do %>
      <em class="bi bi-plus-circle"></em>
      <%= _('Create Team') %>
    <% end %>
  </div>

  <% if @teams.empty? %>
    <div class="text-center mt-5">
      <p class="text-muted"><%= _('You are not a member of any teams yet.') %></p>
      <%= link_to new_team_path, class: 'btn btn-primary' do %>
        <em class="bi bi-plus-circle"></em>
        <%= _('Create Your First Team') %>
      <% end %>
    </div>
  <% else %>
    <div class="row">
      <% @teams.each do |team| %>
        <div class="col-md-6 col-lg-4 mb-3">
          <div class="card h-100">
            <div class="card-body">
              <h5 class="card-title"><%= team.name %></h5>
              <% if team.description.present? %>
                <p class="card-text text-muted"><%= truncate(team.description, length: 100) %></p>
              <% end %>
              <div class="d-flex align-items-center text-muted mb-2">
                <em class="bi bi-people me-1"></em>
                <small><%= pluralize(team.member_count, _('member')) %></small>
                <% membership = team.membership_for(current_user) %>
                <% if membership %>
                  <span class="badge bg-secondary ms-2"><%= membership.role.humanize %></span>
                <% end %>
              </div>
            </div>
            <div class="card-footer">
              <%= link_to _('View Team'), team_path(team), class: 'btn btn-sm btn-outline-primary' %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>
</div>
