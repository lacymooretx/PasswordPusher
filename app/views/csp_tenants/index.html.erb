<% title(_('CSP Tenants')) %>

<main>
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2><%= _('CSP Client Tenants') %></h2>
    <div class="d-flex gap-2">
      <%= button_to sync_csp_tenants_path, method: :post, class: "btn btn-primary" do %>
        <em class="bi bi-arrow-repeat"></em> <%= _('Sync from CIPP') %>
      <% end %>
    </div>
  </div>

  <% if @csp_tenants.any? %>
    <div class="table-responsive">
      <table class="table table-hover">
        <thead>
          <tr>
            <th><%= _('Name') %></th>
            <th><%= _('Domain') %></th>
            <th><%= _('Contact') %></th>
            <th><%= _('SSO') %></th>
            <th><%= _('Onboarded') %></th>
            <th><%= _('Last Synced') %></th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% @csp_tenants.each do |tenant| %>
            <tr>
              <td><%= link_to tenant.name, csp_tenant_path(tenant), class: "text-decoration-none" %></td>
              <td><code><%= tenant.domain %></code></td>
              <td><%= tenant.contact_email || '-' %></td>
              <td>
                <% if tenant.sso_enabled? %>
                  <span class="badge bg-success"><%= _('Enabled') %></span>
                <% else %>
                  <span class="badge bg-secondary"><%= _('Disabled') %></span>
                <% end %>
              </td>
              <td>
                <% if tenant.onboarded? %>
                  <span class="badge bg-success"><%= l(tenant.onboarded_at, format: :short) %></span>
                <% else %>
                  <span class="badge bg-warning text-dark"><%= _('Pending') %></span>
                <% end %>
              </td>
              <td><%= tenant.last_synced_at ? l(tenant.last_synced_at, format: :short) : '-' %></td>
              <td>
                <div class="d-flex gap-1">
                  <%= button_to toggle_sso_csp_tenant_path(tenant), method: :post, class: "btn btn-sm btn-outline-#{tenant.sso_enabled? ? 'danger' : 'success'}", title: tenant.sso_enabled? ? _('Disable SSO') : _('Enable SSO') do %>
                    <em class="bi bi-<%= tenant.sso_enabled? ? 'lock' : 'unlock' %>"></em>
                  <% end %>
                  <% if tenant.contact_email.present? && !tenant.onboarded? %>
                    <%= button_to onboard_csp_tenant_path(tenant), method: :post, class: "btn btn-sm btn-outline-primary", title: _('Send Onboarding Email'), data: { turbo_confirm: _("Send onboarding email to %{email}?") % { email: tenant.contact_email } } do %>
                      <em class="bi bi-envelope"></em>
                    <% end %>
                  <% end %>
                  <%= link_to edit_csp_tenant_path(tenant), class: "btn btn-sm btn-outline-secondary" do %>
                    <em class="bi bi-pencil"></em>
                  <% end %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <div class="mt-3 text-muted small">
      <%= _('%{total} tenants, %{sso} with SSO enabled, %{onboarded} onboarded') % {
        total: @csp_tenants.count,
        sso: @csp_tenants.count(&:sso_enabled?),
        onboarded: @csp_tenants.count(&:onboarded?)
      } %>
    </div>
  <% else %>
    <div class="text-center py-5 text-muted">
      <em class="bi bi-building fs-1 d-block mb-3"></em>
      <p><%= _('No CSP tenants discovered yet.') %></p>
      <p><%= _('Click "Sync from CIPP" to discover your client tenants.') %></p>
    </div>
  <% end %>
</main>
