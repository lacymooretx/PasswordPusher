<!DOCTYPE html>
<html lang="<%= I18n.locale %>" data-controller="theme">
  <head>
    <meta charset="utf-8">
    <meta name="ROBOTS" content="NOODP">
    <meta name="viewport" content="initial-scale=1">
    <title>
      <% if content_for? :title %>
        <%= yield(:title) %> -
      <% end %>
      <%= @team&.name || _('Team Settings') %> - <%= _('Password Pusher') %>
    </title>
    <%= csrf_meta_tags %>
    <%= csp_meta_tag if defined?(csp_meta_tag) %>
    <%= tag.meta name: 'turbo-drive-enabled', content: ENV.key?('TURBO_DRIVE_ENABLED') ? ENV['TURBO_DRIVE_ENABLED'].to_s.downcase : true %>
    <%= render "admin/javascript" %>
  </head>
  <body class="bg-light">
    <div class="min-vh-100 d-flex">
      <!-- Sidebar -->
      <aside class="bg-white shadow border-end" style="width: 280px; min-width: 280px;">
        <%= render "teams/settings_nav" %>
      </aside>

      <!-- Main Content -->
      <main class="flex-grow-1 d-flex flex-column">
        <!-- Top Navigation Bar -->
        <header class="bg-white border-bottom px-4 py-3">
          <div class="d-flex align-items-center justify-content-between">
            <!-- Breadcrumbs -->
            <nav class="d-flex" aria-label="Breadcrumb">
              <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item">
                  <%= link_to teams_path, class: "d-flex align-items-center text-decoration-none text-muted" do %>
                    <em class="bi bi-people me-2"></em>
                    <%= _('All Teams') %>
                  <% end %>
                </li>
                <% if @team %>
                  <li class="breadcrumb-item">
                    <%= link_to @team.name, team_path(@team), class: "text-decoration-none text-muted" %>
                  </li>
                <% end %>
                <% if content_for? :breadcrumbs %>
                  <%= yield :breadcrumbs %>
                <% end %>
              </ol>
            </nav>

            <!-- Actions -->
            <div class="d-flex align-items-center gap-3">
              <%= link_to root_path, class: "btn btn-outline-secondary btn-sm d-flex align-items-center" do %>
                <em class="bi bi-arrow-left me-2"></em>
                <%= _('Back to App') %>
              <% end %>
            </div>
          </div>
        </header>

        <!-- Page Content -->
        <div class="flex-grow-1 p-4">
          <%= render "shared/alerts" %>
          <%= yield %>
        </div>
      </main>
    </div>
  </body>
</html>
