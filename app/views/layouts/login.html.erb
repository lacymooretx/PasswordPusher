<!DOCTYPE html>
<html lang="<%= I18n.locale %>" data-controller="theme">
<head>
  <meta http-equiv="Content-Type" content="text/html; charset=utf-8">

  <title><%= content_for?(:html_title) ? yield(:html_title) : Settings.brand.title %></title>

  <meta content="<%= _('Password Pusher is an application to securely send passwords over the web. Links to passwords expire after a certain number of views and/or time has passed.') %>" name='description'>
  <meta content='width=device-width, initial-scale=1' name='viewport'>

  <%= render partial: "shared/layout_icons", cached: true %>

  <%= render partial: "application/ga", cached: true %>
  <%= render partial: "application/plausible", cached: true %>

  <%= csrf_meta_tags %>
  <%= csp_meta_tag if defined?(csp_meta_tag) %>

  <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
  <%= javascript_include_tag "application", "data-turbo-track": "reload", type: "module" %>
  <%= tag.meta name: 'turbo-drive-enabled', content: ENV.key?('TURBO_DRIVE_ENABLED') ? ENV['TURBO_DRIVE_ENABLED'].to_s.downcase : true %>
</head>

<body class="d-flex flex-column min-vh-100">
  <div class="container-fluid d-flex flex-column min-vh-100 justify-content-center align-items-center">
    <%= render partial: 'shared/alerts' %>
    <main class="col-12 col-sm-8 col-md-6 col-lg-4 text-center">
      <% login_branding = TeamBranding.joins(:logo_attachment).first if defined?(TeamBranding) && Settings.respond_to?(:enable_teams) && Settings.enable_teams %>
      <%= link_to root_path(locale: locale.to_s), hreflang: locale.to_s do %>
        <% if login_branding&.logo&.attached? %>
          <% if login_branding.dark_logo.attached? %>
            <%= image_tag login_branding.logo, alt: login_branding.brand_title || _('Logo'), style: "max-height: 120px; max-width: 100%; height: auto;", class: "light-logo" %>
            <%= image_tag login_branding.dark_logo, alt: login_branding.brand_title || _('Logo'), style: "max-height: 120px; max-width: 100%; height: auto;", class: "dark-logo" %>
          <% else %>
            <%= image_tag login_branding.logo, alt: login_branding.brand_title || _('Logo'), style: "max-height: 120px; max-width: 100%; height: auto;" %>
          <% end %>
        <% elsif Settings.brand.present? && Settings.brand.light_logo.present? %>
          <img src="<%= Settings.brand.light_logo %>" alt="" style="max-height: 120px; max-width: 100%; height: auto;" class="light-logo">
          <img src="<%= Settings.brand.dark_logo %>" alt="" style="max-height: 120px; max-width: 100%; height: auto;" class="dark-logo">
        <% else %>
          <img src="<%= asset_path('logo-transparent-sm-bare.png') %>" alt="<%= _('Password Pusher Logo') %>" style="max-height: 120px; max-width: 100%; height: auto;" class="light-logo">
          <img src="<%= asset_path('logo-transparent-sm-dark-bare.png') %>" alt="<%= _('Password Pusher Logo') %>" style="max-height: 120px; max-width: 100%; height: auto;" class="dark-logo">
        <% end %>
      <% end %>

      <%= yield %>

      <hr class="mt-5">
      <div class='my-3'>
        <%= render "devise/shared/links" %>
      </div>
      <hr class="mt-5">
    </main>
  </div>
</body>
</html>
