<% title(_('Backup Codes')) %>

<main class="">
  <h3 class="mb-4"><%= _('Your Backup Codes') %></h3>

  <div class="alert alert-warning">
    <strong><%= _('Important:') %></strong>
    <%= _('Save these backup codes in a secure location. Each code can only be used once. If you lose access to your authenticator app, you can use one of these codes to sign in.') %>
  </div>

  <div class="card mb-4">
    <div class="card-body">
      <div class="row">
        <% @backup_codes.each do |code| %>
          <div class="col-6 col-md-4 mb-2">
            <code class="fs-5"><%= code %></code>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <div class="d-flex gap-2 mb-4">
    <button class="btn btn-outline-secondary" type="button" onclick="copyBackupCodes()">
      <%= _('Copy All Codes') %>
    </button>
  </div>

  <div class="alert alert-info">
    <%= _('Two-factor authentication is now enabled. You will be asked for a verification code each time you sign in.') %>
  </div>

  <%= link_to _('Done'), edit_user_registration_path, class: "btn btn-primary" %>
</main>

<script>
  function copyBackupCodes() {
    var codes = "<%= @backup_codes.join('\n') %>";
    navigator.clipboard.writeText(codes);
  }
</script>
